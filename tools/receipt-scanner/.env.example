# --- Mistral (OCR + structured extraction) ---
# Get a key at https://console.mistral.ai/
MISTRAL_API_KEY=

# Model used to turn the OCR text into structured receipt data.
# Any Mistral chat model that supports JSON output works.
MISTRAL_TEXT_MODEL=mistral-small-latest

# --- Actual Budget (only needed for direct import with --import) ---
# URL of your sync server, e.g. https://actual.example.com or http://localhost:5006
ACTUAL_SERVER_URL=
# The password you use to log into the sync server
ACTUAL_PASSWORD=
# The Sync ID of the budget (Settings > Advanced > "Sync ID") to import into
ACTUAL_SYNC_ID=
# Optional: end-to-end encryption password, if your budget is encrypted
ACTUAL_E2E_PASSWORD=
# Optional: where to cache the downloaded budget (defaults to ./.actual-cache)
ACTUAL_DATA_DIR=
